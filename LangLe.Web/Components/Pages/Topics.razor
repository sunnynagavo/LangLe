@page "/topics"
@rendermode InteractiveServer
@inject ApiClient Api
@inject IDialogService DialogService

<PageTitle>LangLe - Topics</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight:800;">📚 Learning Topics</MudText>
<MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">Choose a topic and start learning!</MudText>

@if (_loading)
{
    <MudGrid>
        @for (int i = 0; i < 6; i++)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="180px" Style="border-radius:16px;" />
            </MudItem>
        }
    </MudGrid>
}
else
{
    <MudGrid>
        @foreach (var topic in _topics)
        {
            var t = topic;
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="4" Style="border-radius:20px; overflow:hidden; cursor:pointer; transition: transform 0.2s;"
                         Class="topic-card" @onclick="() => SelectTopic(t)">
                    <MudCardContent Class="text-center pa-5">
                        <MudText Typo="Typo.h2" Class="mb-2">@t.IconEmoji</MudText>
                        <MudText Typo="Typo.h5" Style="font-weight:800;">@t.Name</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">@t.Description</MudText>
                        <MudProgressLinear Color="@(t.ProgressPercent >= 100 ? Color.Success : Color.Primary)"
                                           Value="@t.ProgressPercent" Rounded="true" Size="Size.Large" Class="mb-2">
                            <MudText Typo="Typo.body2" Style="font-weight:700;">
                                @($"{t.ProgressPercent:0}%")
                            </MudText>
                        </MudProgressLinear>
                        <MudText Typo="Typo.caption">@t.CompletedLessons / @t.TotalLessons lessons</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>

    @if (_selectedTopic != null && _showLessons)
    {
        <MudOverlay Visible="true" DarkBackground="true" OnClick="CloseLessons" ZIndex="1200" />
        <div style="position:fixed; top:0; right:0; width:420px; max-width:90vw; height:100vh; z-index:1300;
                    background:var(--mud-palette-surface); box-shadow:-4px 0 24px rgba(0,0,0,0.25);
                    display:flex; flex-direction:column; animation: slideIn 0.25s ease-out;">
            <div style="padding:20px 24px; border-bottom:1px solid var(--mud-palette-lines-default);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h5" Style="font-weight:800;">@_selectedTopic.IconEmoji @_selectedTopic.Name</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseLessons" />
                </MudStack>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_selectedTopic.Description</MudText>
            </div>
            <div style="overflow-y:auto; flex:1; padding:8px 16px;">
                <MudList T="LessonDto">
                    @foreach (var lesson in _lessons)
                    {
                        <MudListItem T="LessonDto" Href="@($"/lesson/{lesson.Id}")"
                                     Icon="@(lesson.IsCompleted ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.PlayCircleFilled)"
                                     IconColor="@(lesson.IsCompleted ? Color.Success : Color.Primary)">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudText Style="font-weight:600;">@lesson.Title</MudText>
                                <MudSpacer />
                                <MudChip T="string" Size="Size.Small" Color="@(lesson.IsCompleted ? Color.Success : Color.Default)">
                                    @(lesson.IsCompleted ? "✅ Done" : $"{lesson.ExerciseCount} exercises")
                                </MudChip>
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            </div>
        </div>
    }
}

<style>
    .topic-card:hover {
        transform: translateY(-6px) scale(1.02);
        box-shadow: 0 12px 40px rgba(108,99,255,0.3) !important;
    }
    @@keyframes slideIn {
        from { transform: translateX(100%); }
        to { transform: translateX(0); }
    }
</style>

@code {
    private List<TopicDto> _topics = [];
    private List<LessonDto> _lessons = [];
    private TopicDto? _selectedTopic;
    private bool _loading = true;
    private bool _showLessons;

    protected override async Task OnInitializedAsync()
    {
        _topics = await Api.GetTopicsAsync();
        _loading = false;
    }

    private async Task SelectTopic(TopicDto topic)
    {
        _selectedTopic = topic;
        _lessons = await Api.GetLessonsAsync(topic.Id);
        _showLessons = true;
    }

    private void CloseLessons()
    {
        _showLessons = false;
    }
}
