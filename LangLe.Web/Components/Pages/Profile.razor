@page "/profile"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>LangLe - Profile</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight:800;">👤 Profile</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="ma-auto d-block mt-8" />
}
else if (_profile == null)
{
    <MudStack AlignItems="AlignItems.Center" Class="mt-8">
        <MudText Typo="Typo.h5" Color="Color.Secondary">Please log in to view your profile</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/login">Login</MudButton>
    </MudStack>
}
else
{
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6" Elevation="4" Style="border-radius:20px;">
                <MudStack AlignItems="AlignItems.Center" Spacing="3">
                    <MudText Typo="Typo.h1">@_profile.AvatarEmoji</MudText>
                    <MudText Typo="Typo.h5" Style="font-weight:800;">@_profile.DisplayName</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_profile.Email</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6" Elevation="4" Style="border-radius:20px;">
                <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight:700;">⚙️ Settings</MudText>
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="_displayName" Label="Display Name" Variant="Variant.Outlined" />

                    <MudText Typo="Typo.body2" Style="font-weight:600;">Pick your avatar:</MudText>
                    <MudStack Row="true" Wrap="Wrap.Wrap">
                        @foreach (var emoji in _avatars)
                        {
                            <MudButton Variant="@(_selectedAvatar == emoji ? Variant.Filled : Variant.Outlined)"
                                       Color="Color.Primary" OnClick="@(() => _selectedAvatar = emoji)"
                                       Style="font-size:1.5rem; min-width:50px;">
                                @emoji
                            </MudButton>
                        }
                    </MudStack>

                    <MudSelect @bind-Value="_dailyGoal" Label="Daily Goal" Variant="Variant.Outlined">
                        <MudSelectItem Value="5">5 minutes</MudSelectItem>
                        <MudSelectItem Value="10">10 minutes</MudSelectItem>
                        <MudSelectItem Value="15">15 minutes</MudSelectItem>
                        <MudSelectItem Value="20">20 minutes</MudSelectItem>
                    </MudSelect>

                    <MudSelect @bind-Value="_targetLanguage" Label="Learning Language" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("es")">🇪🇸 Spanish</MudSelectItem>
                        <MudSelectItem Value="@("te")">🇮🇳 Telugu</MudSelectItem>
                    </MudSelect>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveProfile"
                               Disabled="_saving" Style="font-weight:700;">
                        @(_saving ? "Saving..." : "Save Changes ✓")
                    </MudButton>

                    @if (_saved)
                    {
                        <MudAlert Severity="Severity.Success" Dense="true">Profile updated!</MudAlert>
                    }
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private ProfileDto? _profile;
    private bool _loading = true;
    private bool _saving;
    private bool _saved;
    private string _displayName = "";
    private string _selectedAvatar = "🦜";
    private int _dailyGoal = 10;
    private string _targetLanguage = "es";

    private string[] _avatars = ["🦜", "🐶", "🐱", "🦊", "🐼", "🦁", "🐸", "🦉", "🐝", "🦋", "🐙", "🦄"];

    protected override async Task OnInitializedAsync()
    {
        _profile = await Api.GetMeAsync();
        if (_profile != null)
        {
            _displayName = _profile.DisplayName;
            _selectedAvatar = _profile.AvatarEmoji;
            _dailyGoal = _profile.DailyGoalMinutes;
            _targetLanguage = _profile.TargetLanguage;
        }
        _loading = false;
    }

    private async Task SaveProfile()
    {
        _saving = true;
        _saved = false;
        _profile = await Api.UpdateProfileAsync(new UpdateProfileRequest(
            _displayName, _selectedAvatar, _dailyGoal, null, _targetLanguage, null));
        _saving = false;
        _saved = true;
    }
}
