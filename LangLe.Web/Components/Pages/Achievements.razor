@page "/achievements"
@rendermode InteractiveServer
@inject ApiClient Api

<PageTitle>LangLe - Achievements</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight:800;">🏆 Achievements</MudText>
<MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">Collect them all!</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="ma-auto d-block mt-8" />
}
else
{
    <MudGrid>
        @foreach (var a in _achievements)
        {
            <MudItem xs="6" sm="4" md="3">
                <MudPaper Elevation="@(a.IsUnlocked ? 4 : 1)"
                          Style="@($"border-radius:20px; text-align:center; padding:24px; opacity:{(a.IsUnlocked ? 1 : 0.4)}; transition: transform 0.2s;")"
                          Class="achievement-card">
                    <MudText Typo="Typo.h2" Class="mb-2">@a.IconEmoji</MudText>
                    <MudText Typo="Typo.h6" Style="font-weight:800;">@a.Name</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@a.Description</MudText>
                    @if (a.IsUnlocked)
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small" Class="mt-2">✅ Unlocked</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Default" Size="Size.Small" Class="mt-2">🔒 Locked</MudChip>
                    }
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

<style>
    .achievement-card:hover {
        transform: scale(1.05);
    }
</style>

@code {
    private List<AchievementDto> _achievements = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _achievements = await Api.GetAchievementsAsync();
        _loading = false;
    }
}
